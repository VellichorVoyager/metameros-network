REQUEST_TIMEOUT_MS=5000

# For browser polling, Next.js requires NEXT_PUBLIC_ variables.
NEXT_PUBLIC_POLL_INTERVAL_FAST=5000
NEXT_PUBLIC_POLL_INTERVAL_SLOW=30000
NEXT_PUBLIC_REVALIDATE_ON_FOCUS=false

# Optional aliases for parity with docs/backend naming.
POLL_INTERVAL_FAST=5000
POLL_INTERVAL_SLOW=30000

# Gateway host hardening (safe defaults)
ALLOW_CUSTOM_GATEWAY_HOST=false
GATEWAY_ALLOWED_HOSTS=

# Cookie security posture
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# Mutation safety (server-enforced and exposed to UI via /api/router/capabilities)
ENABLE_WRITE_ACTIONS=false
